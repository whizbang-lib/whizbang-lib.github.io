{
  "name": "whizbang-site",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node src/scripts/gen-docs-list.mjs && node src/scripts/gen-docs-index.mjs && node src/scripts/gen-docs-index-versioned.mjs && node src/scripts/gen-sitemap.mjs && ./build-search-index.sh",
    "start": "ng serve --hmr --configuration development",
    "prebuild": "node src/scripts/gen-docs-list.mjs && node src/scripts/gen-docs-index.mjs && node src/scripts/gen-docs-index-versioned.mjs && node src/scripts/gen-sitemap.mjs && node src/scripts/gen-static-docs.mjs && node src/scripts/generate-vscode-feed.mjs && ./build-search-index.sh",
    "gen-static-docs": "node src/scripts/gen-static-docs.mjs",
    "search-index": "./build-search-index.sh",
    "build": "ng build --configuration production --output-hashing=all",
    "preview": "ng serve --configuration production",
    "postinstall": "pnpm exec ng analytics off || true",
    "migrate-docs": "node src/scripts/migrate-docs-version.mjs",
    "validate-links": "node src/scripts/validate-links.mjs",
    "validate-frontmatter": "node src/scripts/validate-frontmatter.mjs"
  },
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "dependencies": {
    "@angular/animations": "~22.0.5",
    "@angular/common": "~22.0.5",
    "@angular/compiler": "~22.0.5",
    "@angular/core": "~22.0.5",
    "@angular/forms": "~22.0.5",
    "@angular/platform-browser": "~22.0.5",
    "@angular/platform-browser-dynamic": "~22.0.5",
    "@angular/router": "~22.0.5",
    "@angular/youtube-player": "^22.0.4",
    "@primeng/themes": "^21.0.4",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.12.0",
    "minisearch": "^7.1.2",
    "ngx-markdown": "^21.1.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.4",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.5",
    "@angular/cli": "~22.0.5",
    "@angular/compiler-cli": "~22.0.5",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^25.5.0",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.5",
    "tailwindcss": "^4.1.10",
    "typescript": "~6.0.2"
  }
}
